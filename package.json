{
  "name": "gmail-mcp",
  "version": "0.4.0",
  "description": "Full Gmail API surface as an MCP server (~55 tools): send, drafts with attachments, threaded reply drafts, labels, filters, settings (vacation/signatures/forwarding/delegates/IMAP/POP/S-MIME), watch, history. Auth: OAuth 2.0 desktop flow with your own Cloud Console OAuth client.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nyybatboy/gmail-mcp.git"
  },
  "keywords": [
    "gmail",
    "mcp",
    "model-context-protocol",
    "anthropic",
    "claude",
    "ai-agents",
    "google-api",
    "oauth"
  ],
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "gmail-cli": "bin/gmail-cli.js",
    "gmail-mcp": "bin/gmail-mcp.js"
  },
  "scripts": {
    "auth": "node bin/gmail-cli.js auth",
    "auth-status": "node bin/gmail-cli.js auth-status",
    "mcp": "node bin/gmail-mcp.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "googleapis": "^144.0.0",
    "open": "^10.1.0"
  }
}
